# PostgreSQL 连接字符串
PG_DSN=host=localhost port=5432 dbname=caigou user=postgres password=yourpassword

# 服务配置
HOST=0.0.0.0
PORT=7000

# 静态文件服务器基础地址（用于拼接图纸下载 URL）
# 例如：http://192.168.0.41:8000
STATIC_BASE_URL=http://localhost:8000

# ===================== 拆图相关配置 =====================

# 图纸文件存放根目录（网络共享盘根路径）
# 例如：E:\\ 或 \\192.168.0.100\cad
CAD_SEARCH_ROOT=E:\\

# ODA 文件转换器路径（DWG <-> DXF 转换工具，必须安装）
# 下载地址：https://www.opendesign.com/guestfiles/oda_file_converter
ODA_FILE_CONVERTER_PATH=D:\AI\ODA\ODAFileConverter.exe

# 拆图结果保存目录（生成的 DWG 文件存放在这里）
# 建议指向当前服务的 static 目录
CHAITU_OUTPUT_DIR=static/dwg/chaidan

# 写入数据库后是否同步更新 supplier_shortlist_chaidan_wujin 表的 dwg 字段
# true=更新，false=不更新（只返回文件路径，不写库）
CHAITU_SAVE_TO_DB=true
